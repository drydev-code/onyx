# Local environment variables for backend test/dev scripts.
# Copy to .env and fill in real values; .env is gitignored.

# Z.AI / GLM API key for backend/scripts/test_glm_search.py
GLM_API_KEY=

# Postgres password used by backend/scripts/test_codex_setup.py when
# shelling out to psql against the dev compose stack.
PGPASSWORD=password

# Codex CLI OAuth refresh token for backend/tests/codex-docker-test/refresh_token.py
# Get this via `codex login` then read ~/.codex/auth.json
CODEX_REFRESH_TOKEN=

# Public hostname Traefik routes to in the dev/staging deploy. Used by
# fix_labels.py to patch docker-compose.yml after a deploy.
ONYX_PUBLIC_HOST=onyx.example.com
